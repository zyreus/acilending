# Amalgated Lending — Node chat/API server (this folder).
# Copy to .env and adjust. Run: npm install && npm start (or use npm run serve:chat from ../).

PORT=8010

# Production: comma-separated SPA origins allowed to use Socket.IO + REST (no trailing slashes). Leave empty in local dev (allows all).
# Point DNS chat.amalgatedlending.com at this Node app; set the same origin in the SPA build (VITE_CHAT_SERVER_URL).
# CHAT_CORS_ORIGINS=https://amalgatedlending.com,https://www.amalgatedlending.com
# Behind nginx/Apache TLS termination: TRUST_PROXY=1
# TRUST_PROXY=1
# TRUST_PROXY_HOPS=1

# Optional: when ../dist is missing, redirect browser hits on this server to Vite (dev only).
# VITE_DEV_SERVER_URL=http://localhost:5173

# Must match VITE_LENDING_ADMIN_API_SECRET (or VITE_CHAT_API_SECRET) in ../.env (min 8 chars).
LENDING_ADMIN_API_SECRET=amalgated-local-chat-secret-v1

JWT_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# SQLite (default) — chat.db is created in this folder unless DB_PATH is set.
DB_PROVIDER=
DB_PATH=chat.db

# Or MySQL — use amalgated_lending_chat only (never amalgated_holdings; that is the Holdings site DB).
# Import schema: db/mysql-init.sql into database amalgated_lending_chat (or run from ../scripts/xampp-databases.sql).
# DB_PROVIDER=mysql
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=amalgated_lending_chat

# Groq AI for visitor chat (optional). Without a key, rule-based replies still work.
# Put the real key only in .env (never commit). No quotes around the key. Server tries model fallbacks if one is retired.
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MAX_TOKENS=512
# GROQ_TEMPERATURE=0.65

# Optional: UTF-8 text file appended to the lending AI FAQ (Groq system prompt). Restart server after edits.
# Paths relative to this folder (cwd when you run npm start) or absolute.
# LENDING_AI_FAQ_PATH=./ai/my-lending-notes.txt

# ── Email (Brevo recommended) — careers/news notifications, loan application confirmations, etc.
# Priority in lib/email.js: BREVO_API_KEY → MailerSend → Resend → SMTP (SMTP_HOST + SMTP_USER + SMTP_PASS).
# Brevo: create API key under SMTP & API → API keys; verify sender domain or single sender for MAIL_FROM.
# BREVO_API_KEY=xkeysib-...
# MAIL_FROM="Amalgated Lending <noreply@yourdomain.com>"
#
# Or SMTP relay (no API key): use Brevo SMTP credentials from the same dashboard section.
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-smtp-login
# SMTP_PASS=xsmtp-...
