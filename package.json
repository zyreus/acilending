{
  "name": "amalgated-lending",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/clear-laravel-bind.cjs",
    "predev:full": "node scripts/clear-laravel-bind.cjs",
    "dev": "concurrently -n laravel,vite -c blue,green \"npm run serve:laravel\" \"npm run dev:vite\"",
    "serve:laravel": "node scripts/serve-laravel.cjs",
    "serve:chat": "cd chat-server && node server.js",
    "dev:vite": "npx vite --config frontend/vite.config.js",
    "dev:vite:delayed": "node scripts/wait-laravel.cjs && npx vite --config frontend/vite.config.js",
    "dev:full": "concurrently -n laravel,vite,chat -c blue,green,magenta \"npm run serve:laravel\" \"npm run dev:vite\" \"npm run serve:chat\"",
    "dev:full:chat": "npm run dev:full",
    "build": "npx vite build --config frontend/vite.config.js",
    "lint": "eslint .",
    "preview": "npx vite preview --config frontend/vite.config.js",
    "composer:install": "composer install --optimize-autoloader --working-dir=amalgated-lending-api",
    "composer:install:prod": "composer install --optimize-autoloader --no-dev --working-dir=amalgated-lending-api",
    "api:cache": "cd amalgated-lending-api && php artisan config:cache && php artisan route:cache && php artisan view:cache"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "6.15.2",
    "@aws-amplify/ui-react-liveness": "^3.5.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "aws-amplify": "^6.16.3",
    "framer-motion": "^12.35.0",
    "gsap": "^3.14.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "socket.io-client": "^4.8.3"
  },
  "overrides": {
    "@aws-amplify/ui-react": "6.15.2"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.2.1",
    "@aws-amplify/backend-cli": "^1.7.2",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1"
  }
}
