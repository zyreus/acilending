# Copy to `.env` or `.env.development.local` for local dev.

# Laravel API port (must match `php artisan serve` / scripts/serve-laravel.cjs)
LARAVEL_PORT=8000

# Vite proxy: browser calls `/api/*` → this origin (see vite.config.js)
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Borrower liveness and all other JWT routes: POST/GET https://<host>/api/v1/...
# Example: POST http://localhost:5173/api/v1/liveness/verify (proxied to Laravel).
# Camera (getUserMedia): use HTTPS or http://localhost (or 127.0.0.1).

# FaceIO (fio.js) — public app ID from https://faceio.net — used by Identity Verification
# VITE_FACEIO_PUBLIC_ID=

# AWS Amplify Face Liveness (FaceLivenessDetector): Cognito Identity Pool (guest) in same region as LIVENESS_AMPLIFY_REGION
# VITE_AWS_COGNITO_IDENTITY_POOL_ID=

# Optional: admin chat bridge (same secret as chat-server/.env when used)
# VITE_LENDING_ADMIN_API_SECRET=

# Node chat server (Socket.IO + CRM). Defaults to http://127.0.0.1:8010 in dev if unset — do NOT point at Laravel.
# VITE_CHAT_DEV_ORIGIN=http://127.0.0.1:8010
# VITE_CHAT_PROXY_TARGET=http://127.0.0.1:8010
# Production / static Apache build: set at build time so the browser can reach Node (or your reverse proxy host).
# VITE_CHAT_SERVER_URL=https://chat.yourdomain.com

# --- cPanel / production (amalgatedlending.com) ---
# Copy `.env.production.example` → `.env.production`, adjust hosts, then `npm run build`.
# Upload `dist/*` to the web root for amalgatedlending.com; host Laravel `public/` on api.amalgatedlending.com (or same host; see amalgated-lending-api/.env.example).
