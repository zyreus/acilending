# Use quotes if the name contains spaces (unquoted values break dotenv parsing and the whole app returns HTTP 500).
APP_NAME="Amalgated Lending"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# React/Vite dev server — password-reset emails link here (see AppServiceProvider).
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
# Laravel lending API only — separate from amalgated_holdings (Holdings) and amalgated_lending_chat (Node chat CRM).
DB_DATABASE=amalgated_lending_db
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail: local dev — MailHog on 127.0.0.1:1025 (or set MAIL_MAILER=log to write to storage/logs). Production: Brevo SMTP. ──
MAIL_MAILER=smtp
# Use 127.0.0.1 on Windows/host; Docker service name "mailhog" only works inside the same compose network.
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Brevo (https://www.brevo.com/) — transactional email for Amalgated Lending API.
#
# (A) REST API — used by Admin CRM “Email lead”, borrower/admin forgot-password, when set (preferred; no SMTP port issues).
#     Create key: Brevo → SMTP & API → API keys. Sender must be verified (Domains or single sender).
# BREVO_API_KEY=xkeysib-...
# BREVO_SENDER_EMAIL=noreply@yourdomain.com
# BREVO_SENDER_NAME="Amalgated Lending"
# BREVO_API_ENDPOINT=https://api.brevo.com/v3
# BREVO_TIMEOUT=30
#
# (B) SMTP — use Laravel’s Mail facade with Brevo relay (e.g. future Mailables, password flows).
#     Set MAIL_MAILER=brevo. Credentials: Brevo → SMTP & API → SMTP → copy login + SMTP key.
# MAIL_MAILER=brevo
# BREVO_SMTP_HOST=smtp-relay.brevo.com
# BREVO_SMTP_PORT=587
# BREVO_SMTP_ENCRYPTION=tls
# BREVO_SMTP_LOGIN=your-login@example.com
# BREVO_SMTP_KEY=xsmtp-...
# MAIL_FROM_ADDRESS and MAIL_FROM_NAME must match a verified sender in Brevo.

# ── AWS (Rekognition) — borrower liveness POST /api/v1/liveness/verify
# IAM: allow rekognition:CompareFaces in AWS_DEFAULT_REGION (see docs/LIVENESS_SETUP.md).
# Reference face: borrower must have a loan with face_photo_path (KYC apply); else API returns 422.
# Frontend camera: HTTPS or http://localhost|127.0.0.1 (getUserMedia).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Liveness (optional — defaults in config/liveness.php)
# LIVENESS_MAX_ATTEMPTS_24H=3
# LIVENESS_MIN_SIMILARITY=85
# LIVENESS_MAX_IMAGE_BYTES=2097152
# FaceIO POST /api/v1/liveness/faceio-verify (must match frontend VITE_FACEIO_PUBLIC_ID app)
# FACEIO_MIN_CONFIDENCE=0.8

# Face Liveness (Amplify UI) — CreateFaceLivenessSession / GetFaceLivenessSessionResults (region must support Face Liveness)
# LIVENESS_AMPLIFY_REGION=us-east-1
# LIVENESS_AMPLIFY_MIN_CONFIDENCE=80

# Face recognition — single image match POST /api/v1/face/verify (see config/face_verification.php)
# FACE_VERIFY_MAX_ATTEMPTS_24H=3
# FACE_VERIFY_MIN_SIMILARITY=85
# FACE_VERIFY_MAX_IMAGE_BYTES=2097152

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ── Amalgated Lending API ──
# First-time admin user (DatabaseSeeder). Override in production.
# ADMIN_SEED_USERNAME=admin
# ADMIN_SEED_PASSWORD=admin123
