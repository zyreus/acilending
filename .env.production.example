# Copy to `.env.production` in this folder, then run `npm run build`.
# Typical cPanel: SPA at https://amalgatedlending.com (contents of `dist/`), Laravel at https://api.amalgatedlending.com (api `public/`).

VITE_LENDING_API_URL=https://api.amalgatedlending.com/api/v1
VITE_LENDING_PUBLIC_URL=https://api.amalgatedlending.com

VITE_AMALGATED_HOLDINGS_URL=https://amalgatedholdings.com

# If the Node chat server is public (optional):
# VITE_CHAT_SERVER_URL=https://chat.amalgatedlending.com
# VITE_LENDING_ADMIN_API_SECRET=match-chat-server-LENDING_ADMIN_API_SECRET

# ── Laravel API (amalgated-lending-api/.env on the server) ──
# Set FRONTEND_URL to this SPA origin (e.g. https://amalgatedlending.com) so CORS + mail links work.
# Optional: CORS_ALLOWED_ORIGINS for extra origins (comma-separated).
#
# ── Node chat-server (.env) ──
# CHAT_CORS_ORIGINS=https://amalgatedlending.com,https://www.amalgatedlending.com
# TRUST_PROXY=1 when behind a reverse proxy
