# Copy to `.env.production` in this folder, then run `npm run build`.
# cPanel layout: SPA → amalgatedlending.com docroot (`dist/*`), Laravel → api.amalgatedlending.com docroot (`public/`), Node chat → chat.amalgatedlending.com (Passenger/PM2).

VITE_LENDING_API_URL=https://api.amalgatedlending.com/api/v1
VITE_LENDING_PUBLIC_URL=https://api.amalgatedlending.com

VITE_AMALGATED_HOLDINGS_URL=https://amalgatedholdings.com

# Node chat (Socket.IO) — same value as chat-server public URL; must match `CHAT_CORS_ORIGINS` on the server.
VITE_CHAT_SERVER_URL=https://chat.amalgatedlending.com
# Must match chat-server `LENDING_ADMIN_API_SECRET` (min 8 chars). Never commit the real value to git.
# VITE_LENDING_ADMIN_API_SECRET=

# If `npm ci` errors with “Missing: … from lock file”, run once: npm run lockfile:sync (after npm install).

# ── Laravel API (amalgated-lending-api/.env on the server) ──
# APP_URL=https://api.amalgatedlending.com
# FRONTEND_URL=https://amalgatedlending.com
# DB_DATABASE=acilending_cpuser_lending   (cPanel MySQL name from phpMyAdmin; user/host from cPanel)
# Optional: CORS_ALLOWED_ORIGINS for extra origins (comma-separated).
#
# ── Node chat-server (.env on chat host) ──
# CHAT_CORS_ORIGINS=https://amalgatedlending.com,https://www.amalgatedlending.com
# TRUST_PROXY=1
